# Smart Trip Supabase 项目 URL（从 Smart-Trip/.env 的 VITE_SUPABASE_URL 抄过来）
SUPABASE_URL=https://xxxxx.supabase.co

# service_role secret（不是 anon public）
# 取法: https://supabase.com/dashboard → 项目 → Settings → API → service_role
# 警告: 此 key 绕过所有 RLS，等同 root，绝不可进 git/聊天
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR...

# 你这个用户在 auth.users 表里的 uuid
# 取法: Supabase Dashboard → Authentication → Users → 点你的账号 → 复制 User UID
DEFAULT_USER_ID=00000000-0000-0000-0000-000000000000
