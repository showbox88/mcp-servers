# =============================================================================
# Smart Trip MCP — 首次部署 .env 模板
#
# 用法：
#   cp .env.example .env
#   再填下面两个 PASTE_HERE
#
# 警告：
#   .env 已经 gitignore，绝不要把真实 key 提交。
#   service_role key 等同数据库 root，泄露后立即 Supabase Dashboard 旋转。
# =============================================================================

# Smart Trip 的 Supabase 项目 URL（已预填，不是 secret）
SUPABASE_URL=https://sqkhtmsjflrfjajingfg.supabase.co

# -----------------------------------------------------------------------------
# 1) Service role / Secret key（绕过 RLS）
#
# 直链：https://supabase.com/dashboard/project/sqkhtmsjflrfjajingfg/settings/api-keys
#
# 找 "Secret keys" 区域 → Reveal → 复制
# 两种格式都可以用：
#   - 新格式：sb_secret_xxx...
#   - 老格式 JWT：eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=PASTE_HERE

# -----------------------------------------------------------------------------
# 2) 你登录 Smart Trip 用的账号在 auth.users 里的 UUID
#
# 直链：https://supabase.com/dashboard/project/sqkhtmsjflrfjajingfg/auth/users
#
# 点你的账号那行 → 右侧详情 → 复制 "User UID"
# 格式：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx（36 字符）
#
# 这个 ID 决定 MCP 代你访问的"用户"，所有 list_trips / create_trip 都绑定到它。
# -----------------------------------------------------------------------------
DEFAULT_USER_ID=PASTE_HERE
