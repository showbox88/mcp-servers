# =============================================================================
# Smart Trip MCP — 首次部署 .env 模板
#
# 用法：
#   cp .env.example .env
#   再填下面两个 PASTE_HERE
#
# 警告：
#   .env 已经 gitignore，绝不要把真实 key 提交。
#   service_role key 等同数据库 root，泄露后立即 Supabase Dashboard 旋转。
# =============================================================================

# Smart Trip 的 Supabase 项目 URL（已预填，不是 secret）
SUPABASE_URL=https://sqkhtmsjflrfjajingfg.supabase.co

# -----------------------------------------------------------------------------
# 1) Service role / Secret key（绕过 RLS）
#
# 直链：https://supabase.com/dashboard/project/sqkhtmsjflrfjajingfg/settings/api-keys
#
# 找 "Secret keys" 区域 → Reveal → 复制
# 两种格式都可以用：
#   - 新格式：sb_secret_xxx...
#   - 老格式 JWT：eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# -----------------------------------------------------------------------------
SUPABASE_SERVICE_ROLE_KEY=PASTE_HERE

# -----------------------------------------------------------------------------
# 2) 你登录 Smart Trip 用的账号在 auth.users 里的 UUID
#
# 直链：https://supabase.com/dashboard/project/sqkhtmsjflrfjajingfg/auth/users
#
# 点你的账号那行 → 右侧详情 → 复制 "User UID"
# 格式：xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx（36 字符）
#
# 这个 ID 决定 MCP 代你访问的"用户"，所有 list_trips / create_trip 都绑定到它。
# -----------------------------------------------------------------------------
DEFAULT_USER_ID=PASTE_HERE

# =============================================================================
# 仅 HTTP 部署用（本地 stdio 模式不需要这部分）
# =============================================================================

# -----------------------------------------------------------------------------
# 3) Bearer token —— Claude.ai connector / 远程 client 调用 MCP 时必须带
#
# 生成方法（任选）：
#   Linux:    openssl rand -hex 32
#   PowerShell: -join ((1..64) | ForEach { '{0:x}' -f (Get-Random -Max 16) })
#
# 至少 32 字符（hex 64 字符更稳）。轮换：换掉这里的值 + 重启服务 + 在
# Claude.ai connector 设置里同步更新。
# -----------------------------------------------------------------------------
MCP_BEARER_TOKEN=PASTE_HERE

# -----------------------------------------------------------------------------
# 4) HTTP 监听配置（默认值通常不用改）
# -----------------------------------------------------------------------------
# 端口号，Tailscale serve/funnel 反向代理到这里
MCP_HTTP_PORT=3001
# 监听地址 —— 默认只 loopback，靠 Tailscale Funnel 暴露公网。除非你知道在干什么，不要改成 0.0.0.0。
MCP_HTTP_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# 5) 公网 base URL —— music 工具用它构造播放 URL
#
# Tailscale Funnel 暴露的 https://<vm>.<tailnet>.ts.net 这个完整 URL，不带尾斜杠。
# 没设置的话，music_search/random 等工具返回的 url 字段会是 "/audio/...." 相对路径，
# 用户点了打不开。
# -----------------------------------------------------------------------------
MCP_PUBLIC_URL=https://debian.tail4cfa2.ts.net

# -----------------------------------------------------------------------------
# 6) 媒体目录（默认 /opt/music，music 工具会扫描这里建索引）
# -----------------------------------------------------------------------------
# MCP_MEDIA_DIR=/opt/music
